# Supabase — get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # server-only, never expose to client

# Contact form — recipient email for mailto: fallback
CONTACT_EMAIL=info@zizkovtunnel.cz

# Site URL — used for Open Graph absolute image URLs
NEXT_PUBLIC_SITE_URL=https://zizkovtunnel.cz
