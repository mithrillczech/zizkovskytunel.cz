# Supabase — get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # server-only, never expose to client

# Resend — get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Contact form — recipient email address (will move to Supabase admin config later)
CONTACT_EMAIL=petr@machackovi.net

# Site URL — used for Open Graph absolute image URLs
NEXT_PUBLIC_SITE_URL=https://zizkovtunnel.cz
